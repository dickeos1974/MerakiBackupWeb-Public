@page
@model MerakiBackupWeb.Pages.RestoreVlanModel

<h1>Restore VLAN</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <p style="color:green; font-weight:bold;">@Model.StatusMessage</p>
}

@if (!string.IsNullOrWhiteSpace(Model.PreviewMessage))
{
    <p style="color:darkorange; font-weight:bold;">@Model.PreviewMessage</p>
}

<p>
    <a href="/">Back to Backup</a> |
    <a href="/Backups">Backup History</a> |
    <a href="/RestoreSsid">Restore SSID</a>
</p>

<form method="get">
    <label>Select backup:</label>
    <select name="SelectedBackup" onchange="this.form.submit()">
        <option value="">-- Select backup --</option>

        @foreach (var backup in Model.BackupFolders)
        {
            <option value="@backup" selected="@(backup == Model.SelectedBackup)">
                @backup
            </option>
        }
    </select>

    @if (!string.IsNullOrWhiteSpace(Model.SelectedBackup))
    {
        <br />
        <br />

        <label>Select VLAN file:</label>
        <select name="SelectedFile" onchange="this.form.submit()">
            <option value="">-- Select VLAN file --</option>

            @foreach (var file in Model.VlanFiles)
            {
                <option value="@file" selected="@(file == Model.SelectedFile)">
                    @file
                </option>
            }
        </select>

        <input type="hidden" name="SelectedBackup" value="@Model.SelectedBackup" />
    }
    @if (!string.IsNullOrWhiteSpace(Model.SelectedFile))
    {
        <br />
        <br />

        <label>Select target network:</label>
        <select name="SelectedNetworkId" onchange="this.form.submit()">
            <option value="">-- Select network --</option>

            @foreach (var net in Model.Networks)
            {
                var id = net["id"]?.ToString();
                var name = net["name"]?.ToString();

                <option value="@id" selected="@(id == Model.SelectedNetworkId)">
                    @name
                </option>
            }
        </select>

        <input type="hidden" name="SelectedBackup" value="@Model.SelectedBackup" />
        <input type="hidden" name="SelectedFile" value="@Model.SelectedFile" />
    }
</form>

@if (Model.Vlans.Any())
{
    <style>
        table {
            border-collapse: collapse;
        }

        th, td {
            padding: 8px 12px;
            vertical-align: middle;
        }

        button {
            padding: 4px 10px;
        }
    </style>
    <h2>VLAN Preview</h2>

    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>VLAN ID</th>
                <th>Name</th>
                <th>Subnet</th>
                <th>Appliance IP</th>
                <th>DHCP Handling</th>
                <th>Preview</th>
                <th>Confirm</th>
                <th>Restore</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vlan in Model.Vlans)
            {
                <tr>
                    <td>@GetValue(vlan, "id")</td>
                    <td>@GetValue(vlan, "name")</td>
                    <td>@GetValue(vlan, "subnet")</td>
                    <td>@GetValue(vlan, "applianceIp")</td>
                    <td>@GetValue(vlan, "dhcpHandling")</td>
                    <td>
                        <form method="post" asp-page-handler="Preview">
                            <input type="hidden" name="SelectedBackup" value="@Model.SelectedBackup" />
                            <input type="hidden" name="SelectedFile" value="@Model.SelectedFile" />
                            <input type="hidden" name="SelectedNetworkId" value="@Model.SelectedNetworkId" />
                            <input type="hidden" name="VlanId" value="@GetValue(vlan, "id")" />

                            <button type="submit">Preview</button>
                        </form>
                    </td>
                    <td>
                        <form method="post" asp-page-handler="Restore" style="display:flex; gap:8px; align-items:center;">
                            <input type="hidden" name="SelectedBackup" value="@Model.SelectedBackup" />
                            <input type="hidden" name="SelectedFile" value="@Model.SelectedFile" />
                            <input type="hidden" name="SelectedNetworkId" value="@Model.SelectedNetworkId" />
                            <input type="hidden" name="VlanId" value="@GetValue(vlan, "id")" />

                            <label style="display:flex; gap:4px; align-items:center; margin:0;">
                                <input type="checkbox" name="ConfirmRestore" value="true" />
                                Confirm
                            </label>
                        </form>
                    </td>
                    <td>
                        <button type="submit">Restore</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    private static string GetValue(Dictionary<string, object> item, string key)
    {
        return item.TryGetValue(key, out var value) ? value?.ToString() ?? "" : "";
    }
}